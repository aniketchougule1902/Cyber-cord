# =============================================================================
# CyberCord – Unified Environment Variables
# Copy this file to .env and fill in the real values before running.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend (Express API Gateway – Port 4000)
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
JWT_SECRET=your_jwt_secret_min_32_chars
PYTHON_SERVICES_URL=http://localhost:8000
AI_ENGINE_URL=http://localhost:5001
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
TOOL_RATE_LIMIT_MAX=10
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Python OSINT Services (FastAPI – Port 8000)
# -----------------------------------------------------------------------------
PYTHON_ENV=development
HIBP_API_KEY=your_haveibeenpwned_api_key
ABUSEIPDB_API_KEY=your_abuseipdb_api_key
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000
MAX_REQUESTS_PER_MINUTE=60

# -----------------------------------------------------------------------------
# AI Engine (OpenAI-compatible – Port 5001)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview
MAX_TOKENS=4096
TEMPERATURE=0.3
BACKEND_API_KEY=internal_service_key

# -----------------------------------------------------------------------------
# Frontend (Next.js – Port 3000)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=CyberCord
NEXT_PUBLIC_APP_VERSION=1.0.0
