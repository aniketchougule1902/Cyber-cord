# =============================================================================
# CyberCord – Unified Environment Variables
# Copy this file to .env and fill in the real values before running.
#
# For Vercel deployment:
#   • Deploy the /backend folder as a separate Vercel project and copy its
#     deployment URL into NEXT_PUBLIC_BACKEND_URL and CORS_ORIGIN below.
#   • Set all NEXT_PUBLIC_* variables in the /frontend Vercel project settings.
#   • Set all other variables in the /backend Vercel project settings.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend (Express API Gateway – Port 4000 locally, serverless on Vercel)
# -----------------------------------------------------------------------------
# Vercel automatically sets NODE_ENV=production; use 'development' locally
NODE_ENV=development
PORT=4000
SUPABASE_URL=https://valskfspcyfrnllojahy.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZhbHNrZnNwY3lmcm5sbG9qYWh5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY1ODA1ODIsImV4cCI6MjA5MjE1NjU4Mn0.dFD9Srkao8drf4VgIOP1VuD67KhaOEUvYO_d_7aBOuM
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZhbHNrZnNwY3lmcm5sbG9qYWh5Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NjU4MDU4MiwiZXhwIjoyMDkyMTU2NTgyfQ.oPci1wHh6WtAeCwlA3FrS047M6wdZSJBA_xZF1CDi6Y
JWT_SECRET=ca8a375c-9cb5-47e3-b197-21c7abe2b03c
PYTHON_SERVICES_URL=https://your-python-service.vercel.app
AI_ENGINE_URL=https://your-ai-engine.vercel.app
# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGIN=https://your-frontend.vercel.app,https://your-custom-domain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
TOOL_RATE_LIMIT_MAX=10
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Python OSINT Services (FastAPI)
# -----------------------------------------------------------------------------
# Use 'production' when deploying; 'development' locally
PYTHON_ENV=development
HIBP_API_KEY=your_haveibeenpwned_api_key
ABUSEIPDB_API_KEY=your_abuseipdb_api_key
# Comma-separated list of allowed origins for the Python service
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-backend.vercel.app
MAX_REQUESTS_PER_MINUTE=60

# -----------------------------------------------------------------------------
# AI Engine (OpenAI-compatible)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview
MAX_TOKENS=4096
TEMPERATURE=0.3
BACKEND_API_KEY=internal_service_key

# -----------------------------------------------------------------------------
# Frontend (Next.js – set these in Vercel project settings under /frontend)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://valskfspcyfrnllojahy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZhbHNrZnNwY3lmcm5sbG9qYWh5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY1ODA1ODIsImV4cCI6MjA5MjE1NjU4Mn0.dFD9Srkao8drf4VgIOP1VuD67KhaOEUvYO_d_7aBOuM
# Full URL of the deployed backend (no trailing slash)
NEXT_PUBLIC_BACKEND_URL=https://your-backend.vercel.app
NEXT_PUBLIC_APP_NAME=CyberCord
NEXT_PUBLIC_APP_VERSION=1.0.0

